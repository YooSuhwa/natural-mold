# Runtime mode. ``production`` makes the server refuse to boot when any
# of the auth/cookie/CORS/encryption hardening checks fail (see
# app/security/production_check.py). Leave as ``dev`` locally; warnings
# for the same checks still print so you see exactly what blocks prod.
APP_ENV=dev

# Database
DATABASE_URL=postgresql+asyncpg://moldy:moldy@localhost:5432/moldy
DATABASE_URL_SYNC=postgresql://moldy:moldy@localhost:5432/moldy
CHECKPOINTER_POOL_MIN_SIZE=2
CHECKPOINTER_POOL_MAX_SIZE=20
# SQLAlchemy engine pool (postgresql URL에만 적용)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# LLM API Keys — UI의 Credentials 화면에서 등록하는 것을 권장한다 (ADR-013).
# ENV에 두면 dev 부팅 시 system credential로 자동 bootstrap되지만 필수는 아니며,
# production에서는 자동 생성을 건너뛰고 super_user가 직접 등록한다.
# 필요 시 아래 키를 추가:
#   OPENAI_API_KEY / ANTHROPIC_API_KEY / GOOGLE_API_KEY
#   OPENROUTER_API_KEY (Agent image generation)

# Encryption key — Fernet (legacy; superseded by ENCRYPTION_KEYS in M5)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Encryption keys — Cipher V2 (REQUIRED, comma-separated 64-char hex; first is active)
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# Add a new key to the front to begin rotation; the old key stays for decryption.
ENCRYPTION_KEYS=

# External Secrets — Vault (optional)
EXTERNAL_SECRETS_ENABLED=false
VAULT_URL=
VAULT_TOKEN=
VAULT_KV_MOUNT=secret

# Credential rotation cron (APScheduler crontab; default = weekly Sunday 03:00)
CREDENTIAL_ROTATION_CRON=0 3 * * 0

# Refresh-token whitelist GC. Deletes refresh_tokens rows whose
# expires_at is older than the retention window. Default: 05:00 UTC daily,
# 1-day retention beyond expiry (replay detection still classifies a
# barely-expired hash). ADR-016 §4.2.
REFRESH_TOKEN_GC_CRON=0 5 * * *
REFRESH_TOKEN_GC_RETENTION_DAYS=1

# Skill-builder draft workspace GC (skill-studio phase 1). State-based:
# completed/abandoned sessions past the retention are reaped; sessions whose
# draft conversation was GC'd (dead) are marked abandoned after the same
# retention; non-completed sessions idle past SKILL_DRAFT_ABANDON_DAYS are
# marked abandoned (<=0 disables the idle rule — sessions with a live
# conversation are then kept indefinitely).
SKILL_DRAFT_GC_CRON=45 * * * *
SKILL_DRAFT_GC_RETENTION_HOURS=24
SKILL_DRAFT_ABANDON_DAYS=14

# Naver Open API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Tavily Search
TAVILY_API_KEY=

# Google Custom Search
GOOGLE_CSE_ID=your-google-cse-id

# Google Chat Webhook
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX

# Google Workspace OAuth2 (Gmail, Calendar)
# 1. Google Cloud Console에서 OAuth Client ID (Desktop) 생성
# 2. scripts/google_oauth_setup.py 실행하여 refresh_token 발급
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token


# LangSmith (optional, for tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=moldy

# Langfuse trace debugger (optional)
# Unset LANGFUSE_ENABLED to auto-enable when the three connection values exist.
# Set LANGFUSE_ENABLED=false to force the local message_events fallback.
# LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_PROJECT=moldy
LANGFUSE_CAPTURE_INPUT_OUTPUT=true
LANGFUSE_REDACTION_ENABLED=true
LANGFUSE_SAMPLE_RATE=1.0

# ----- ADR-016: multi-user auth -----
# JWT signing secret. REQUIRED in production (>= 32 bytes random).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# If empty in dev, app/auth/jwt.py emits an ephemeral key + warning.
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
CSRF_TOKEN_EXPIRE_MINUTES=60

# Cookie names (rename only if integrating an existing reverse proxy)
COOKIE_NAME_ACCESS=moldy_at
COOKIE_NAME_REFRESH=moldy_rt
COOKIE_NAME_CSRF=moldy_csrf

# In dev (HTTP) Secure must be false or browsers reject cookies.
# Production deployments MUST set COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# First user to register is auto-promoted to super_user — convenient for
# bootstrap. Toggle off (false) immediately after the operator account
# exists in production. See ADR-016 §8.4.
ALLOW_FIRST_USER_AS_ADMIN=true

# Local Playwright E2E account seed. This is skipped automatically in production.
E2E_SEED_USER_ENABLED=true
E2E_USER_EMAIL=playwright-e2e@moldy.dev
E2E_USER_PASSWORD=correct horse battery staple 42
E2E_USER_NAME=E2E User
E2E_SCRIPTED_MODEL_ENABLED=false
E2E_TEST_HELPERS_ENABLED=false

# E2E real-LLM (OpenAI-compatible, e.g. LiteLLM). Set all three to make the
# conversational builder / assistant / subagent / real chat run end-to-end.
# seed.e2e_llm provisions a system credential + Model + System LLM text_primary.
# Leave empty for keyless E2E (scripted model only). Never committed.
E2E_LLM_BASE_URL=
E2E_LLM_API_KEY=
E2E_LLM_MODEL=

# Durable chat run lifecycle. Active runs older than this heartbeat threshold
# are considered stale by attach/sweeper logic.
CHAT_RUN_STALE_AFTER_SECONDS=300
CHAT_RUN_STALE_SWEEP_INTERVAL_SECONDS=60

# Skill JavaScript runner for built-in package skills.
SKILL_MAX_PACKAGE_BYTES=52428800
SKILL_MAX_PACKAGE_FILES=1000
SKILL_NODE_BINARY=node
SKILL_NODE_MODULES_DIR=./skill-node/node_modules

# Skill evaluation worker.
SKILL_EVALUATION_ENABLED=true
SKILL_EVALUATION_MAX_CONCURRENT=1
SKILL_EVALUATION_QUEUE_MAX_SIZE=20
SKILL_EVALUATION_RUN_TIMEOUT_SECONDS=180
SKILL_EVALUATION_CASE_TIMEOUT_SECONDS=60

# CORS allowed origins (comma-separated). allow_credentials=true forces
# explicit origins — wildcard ("*") is rejected by browsers. Add every
# FE domain (prod, staging, custom subdomains) the API will be called from.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- ADR-017: marketplace k-skill importer -----
# super_user 전용 CLI (`uv run python -m app.scripts.sync_k_skill --ref main`)
# 가 사용하는 upstream 설정. upstream repo는 read-only — 직접 수정 금지.
# 자세한 흐름은 docs/design-docs/adr-017-marketplace-resources.md 참조.
K_SKILL_UPSTREAM_URL=https://github.com/NomaDamas/k-skill.git
K_SKILL_UPSTREAM_REF=main
# CLI가 git clone/fetch mirror로 사용하는 로컬 경로.
K_SKILL_SYNC_DIR=./data/upstreams/k-skill
# 검증 완료된 .skill 패키지가 immutable snapshot으로 저장될 경로.
# `marketplace_versions/<version_id>/` 하위에 저장된다.
K_SKILL_BUILTIN_STORAGE_DIR=./data/marketplace/k-skill
