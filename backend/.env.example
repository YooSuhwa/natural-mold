# Database
DATABASE_URL=postgresql+asyncpg://moldy:moldy@localhost:5432/moldy
DATABASE_URL_SYNC=postgresql://moldy:moldy@localhost:5432/moldy

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-key

# Encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Naver Open API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Google Custom Search
GOOGLE_CSE_ID=your-google-cse-id

# Google Chat Webhook
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=XXXX&token=XXXX

# Google Workspace OAuth2 (Gmail, Calendar)
# 1. Google Cloud Console에서 OAuth Client ID (Desktop) 생성
# 2. scripts/google_oauth_setup.py 실행하여 refresh_token 발급
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token

# LangSmith (optional, for tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=moldy
