{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moldy/model-catalog/schema.json",
  "title": "Moldy Model Catalog",
  "description": "Three-layer merged registry of AI model metadata (provider defaults + model defaults + provider-specific overrides)",
  "type": "object",
  "required": ["version", "updated_at", "providers", "models", "provider_models"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of last build"
    },
    "providers": {
      "type": "object",
      "description": "Provider definitions keyed by provider slug",
      "additionalProperties": {"$ref": "#/$defs/provider"}
    },
    "models": {
      "type": "object",
      "description": "Model defaults keyed by canonical model name (provider-agnostic)",
      "additionalProperties": {"$ref": "#/$defs/model"}
    },
    "provider_models": {
      "type": "object",
      "description": "Provider-specific overrides keyed by 'provider/model'",
      "additionalProperties": {"$ref": "#/$defs/provider_model"}
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "required": ["display_name"],
      "additionalProperties": true,
      "properties": {
        "display_name": {"type": "string"},
        "website": {"type": ["string", "null"]},
        "docs_url": {"type": ["string", "null"]},
        "pricing_url": {"type": ["string", "null"]},
        "status_url": {"type": ["string", "null"]},
        "api_type": {
          "type": "string",
          "enum": ["openai", "anthropic", "gemini", "cohere", "mistral", "custom"]
        },
        "default_base_url": {"type": ["string", "null"]},
        "default_rate_limits": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "rpm": {"type": ["integer", "null"]},
            "tpm": {"type": ["integer", "null"]},
            "rpd": {"type": ["integer", "null"]}
          }
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "display_name": {"type": ["string", "null"]},
        "owned_by": {"type": ["string", "null"]},
        "context_window": {"type": ["integer", "null"]},
        "max_output_tokens": {"type": ["integer", "null"]},
        "cost_per_input_token": {"type": ["number", "string", "null"]},
        "cost_per_output_token": {"type": ["number", "string", "null"]},
        "input_modalities": {"type": ["array", "null"], "items": {"type": "string"}},
        "output_modalities": {"type": ["array", "null"], "items": {"type": "string"}},
        "supports_vision": {"type": ["boolean", "null"]},
        "supports_function_calling": {"type": ["boolean", "null"]},
        "supports_reasoning": {"type": ["boolean", "null"]},
        "rankings": {
          "type": ["object", "null"],
          "additionalProperties": {"type": ["number", "integer", "null"]}
        },
        "sources": {
          "type": ["array", "null"],
          "items": {"type": "string"}
        }
      }
    },
    "provider_model": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_ref": {"type": ["string", "null"]},
        "provider_model_id": {"type": ["string", "null"]},
        "enabled": {"type": ["boolean", "null"]},
        "context_window": {"type": ["integer", "null"]},
        "max_output_tokens": {"type": ["integer", "null"]},
        "cost_per_input_token": {"type": ["number", "string", "null"]},
        "cost_per_output_token": {"type": ["number", "string", "null"]},
        "rankings": {
          "type": ["object", "null"],
          "additionalProperties": {"type": ["number", "integer", "null"]}
        },
        "sources": {
          "type": ["array", "null"],
          "items": {"type": "string"}
        }
      }
    }
  }
}
