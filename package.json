{
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "backend/**/*.py": [
      "uv run --directory backend ruff check --fix",
      "uv run --directory backend ruff format"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "prettier --write",
      "frontend/node_modules/.bin/eslint --config frontend/eslint.config.mjs --fix"
    ]
  }
}
