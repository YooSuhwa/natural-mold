# Frontend dev server -> FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Playwright E2E auth account.
# Used by e2e/global-setup.mjs to create a logged-in storageState once per run.
# Keep real shared/staging credentials out of git; override these locally/CI.
E2E_USER_EMAIL=e2e@moldy.local
E2E_USER_PASSWORD=e2e-password-change-me

# Mock-only E2E mode. Set to 1 only for specs that mock every /api/* request.
# PW_SKIP_BACKEND=1
