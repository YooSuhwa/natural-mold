{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "preflight": "node scripts/preflight.mjs",
    "preflight:full": "pnpm preflight && pnpm lint && pnpm lint:a11y && pnpm lint:type-safety && pnpm lint:e2e-hygiene && pnpm lint:i18n && pnpm lint:design-system && pnpm lint:frontend-architecture:strict && pnpm build",
    "prepare:assets": "node scripts/copy-rhwp-wasm.mjs",
    "dev": "pnpm prepare:assets && next dev",
    "build": "pnpm prepare:assets && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "lint:a11y": "node scripts/check-jsx-a11y.mjs",
    "lint:type-safety": "node scripts/check-type-safety.mjs",
    "lint:e2e-hygiene": "node scripts/check-e2e-hygiene.mjs",
    "lint:design-system": "node scripts/check-design-system.mjs",
    "lint:frontend-architecture": "node scripts/check-frontend-architecture.mjs",
    "lint:frontend-architecture:strict": "node scripts/check-frontend-architecture.mjs --strict",
    "lint:i18n": "node scripts/check-static-i18n.mjs",
    "lint:i18n:strict": "node scripts/check-static-i18n.mjs --strict-ascii",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:legacy": "NEXT_PUBLIC_CHAT_RUNTIME=legacy playwright test",
    "test:e2e:langgraph-v3": "NEXT_PUBLIC_CHAT_RUNTIME=langgraph_v3 E2E_WORKERS=1 playwright test e2e/chat-langgraph-v3.spec.ts e2e/chat-langgraph-v3-visual-matrix.spec.ts e2e/draft-conversation-langgraph-v3.spec.ts --workers=1",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.18",
    "@assistant-ui/react-langchain": "^0.0.13",
    "@assistant-ui/react-streamdown": "^0.3.3",
    "@base-ui/react": "^1.3.0",
    "@evilmartians/agent-prism-data": "^0.0.9",
    "@evilmartians/agent-prism-types": "^0.0.9",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph-sdk": "^1.9.21",
    "@langchain/react": "^1.0.22",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-tabs": "^1.1.13",
    "@rhwp/core": "0.7.15",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/jszip": "^3.4.1",
    "@xyflow/react": "^12.10.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "docx-preview": "0.3.7",
    "jotai": "^2.19.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "next": "16.2.2",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "pptxviewjs": "1.1.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-json-pretty": "^2.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "smol-toml": "^1.6.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.96.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "sharp"
    ]
  }
}
